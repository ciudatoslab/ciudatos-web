---
import Layout from "../../layouts/Layout.astro"

const miembros = [
  { nombre: "Alexandra Crespo",  archivo: "Alexandra Crespo.png" },
  { nombre: "Claudia Rojas",     archivo: "Claudia Rojas.png" },
  { nombre: "Darling Hurtado",   archivo: "Darling Hurtado.png" },
  { nombre: "Denny Chura",       archivo: "Denny Chura.png" },
  { nombre: "Diego Bustamante",  archivo: "Diego Bustamante.png" },
  { nombre: "Erick Carrasco",    archivo: "Erick Carrasco.png" },
  { nombre: "Jimena Villca",     archivo: "Jimena Villa.png" },
  { nombre: "Jhoana Huanca",     archivo: "Jhoana Huanca.png" },
  { nombre: "Jocabet Alí",       archivo: "Jocabet.png" },
  { nombre: "Pablo Gómez",       archivo: "Pablo Gomez.png" },
  { nombre: "Silvana Cachi",     archivo: "Silvana Cachi.png" },
  { nombre: "Silvia Vasquez",    archivo: "Silvia Vasquez.png" },
  { nombre: "Teresa Mamani",     archivo: "Teresa Mamani.png" },
  { nombre: "Thamy Montecinos",  archivo: "Thamy Montecinos.png" },
  { nombre: "Xisel Canaviri",    archivo: "Xisel Canaviri.png" },
]
---

<Layout title="Miembros de nuestro equipo">
  <section class="flex flex-col gap-12 items-center py-8 px-4">
    <h2 class="text-3xl sm:text-4xl text-azul-ciudatos text-center font-bold">
      Miembros de nuestro equipo
    </h2>

    <!-- Coordinadora del proyecto -->
    <div class="flex flex-col items-center gap-8 w-full max-w-4xl">
      <h3 class="text-xl sm:text-2xl text-azul-ciudatos font-semibold text-center">
        Coordinadora del proyecto
      </h3>

      <div class="flex flex-col items-center gap-3">
        <div class="w-36 h-36 sm:w-44 sm:h-44 rounded-full overflow-hidden border-4 border-verde-ciudatos shadow-md">
          <img
            src="/img/miembros/valeria-peredo.jpg"
            alt="Valeria Peredo"
            class="w-full h-full object-cover"
          />
        </div>
        <p class="text-lg sm:text-xl font-bold text-texto text-center">
          Valeria Peredo
        </p>
        <p class="text-sm sm:text-base font-semibold uppercase tracking-widest text-sub-texto text-center">
          Antropóloga Urbana y Digital
        </p>

        <!-- Íconos de redes y CV -->
        <div class="flex gap-4 mt-1">
          <!-- LinkedIn -->
          <a
            href="https://www.linkedin.com/in/valeria-peredo-rodr%C3%ADguez-771765141/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-azul-ciudatos hover:text-verde-ciudatos transition-colors duration-300"
            aria-label="LinkedIn de Valeria Peredo"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>

          <!-- ResearchGate -->
          <a
            href="https://www.researchgate.net/profile/Valeria-Rodriguez-40"
            target="_blank"
            rel="noopener noreferrer"
            class="text-azul-ciudatos hover:text-verde-ciudatos transition-colors duration-300"
            aria-label="ResearchGate de Valeria Peredo"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 100 100">
              <circle cx="50" cy="50" r="50" fill="currentColor"/>
              <text x="10" y="82" font-family="Georgia, 'Times New Roman', serif" font-size="68" font-weight="normal" fill="white">R</text>
              <text x="57" y="47" font-family="Georgia, 'Times New Roman', serif" font-size="38" font-weight="normal" fill="white">G</text>
            </svg>
          </a>

          <!-- CV / Academia -->
          <a
            href="https://umss.academia.edu/ValeriaPeredoRodr%C3%ADguez/CurriculumVitae"
            target="_blank"
            rel="noopener noreferrer"
            class="text-azul-ciudatos hover:text-verde-ciudatos transition-colors duration-300"
            aria-label="Currículum de Valeria Peredo"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM6 20V4h5v7h7v9H6zm2-5h8v1.5H8V15zm0-3h8v1.5H8V12zm0-3h4v1.5H8V9z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Equipo -->
    <div class="flex flex-col items-center gap-8 w-full max-w-4xl">
      <h3 class="text-xl sm:text-2xl text-azul-ciudatos font-semibold text-center">
        Pasantes y voluntarios
      </h3>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-8 gap-y-10 w-full">
        {miembros.map((m) => (
          <div class="flex flex-col items-center gap-3">
            <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden border-4 border-verde-ciudatos shadow-md">
              <img
                src={`/img/miembros/${m.archivo}`}
                alt={m.nombre}
                class="w-full h-full object-cover"
              />
            </div>
            <p class="text-base sm:text-lg font-bold text-texto text-center">
              {m.nombre}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>